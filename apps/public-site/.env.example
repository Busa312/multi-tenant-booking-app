API_URL="http://localhost:3001"

# Shared secret checked by POST /api/revalidate — must match apps/api's
# REVALIDATE_SECRET, which apps/api sends after a CMS tenant-colors save.
REVALIDATE_SECRET="change-me-in-production"

# Origin allowed to postMessage draft colors into an embedded preview iframe
# (apps/cms's BrandingSettings page) — must be exact (scheme+host+port, no
# trailing slash). NEXT_PUBLIC_ prefix required so it's readable client-side.
NEXT_PUBLIC_CMS_ORIGIN="http://localhost:5173"
