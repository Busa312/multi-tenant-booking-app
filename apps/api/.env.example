# Owner/migration connection — used by `prisma migrate`/`prisma generate` only.
# Table owners bypass Postgres RLS, so the running API must NOT use this one.
# Port 5433 (not 5432) on the host side — see docker-compose.yml.
DATABASE_URL="postgresql://booking:booking@localhost:5433/booking?schema=public"

# Runtime connection for the API itself: a non-superuser, non-owner role
# (created in docker/postgres/init.sql) so RLS policies actually apply.
APP_DATABASE_URL="postgresql://booking_app:booking_app@localhost:5433/booking?schema=public"

REDIS_URL="redis://localhost:6379"
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="8h"
PORT=3001
