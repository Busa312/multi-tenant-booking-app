VITE_API_URL="http://localhost:3001"

# Used to build the live preview iframe's src in BrandingSettings — the
# tenant's public site is at {subdomain}.{VITE_PUBLIC_SITE_BASE_DOMAIN}.
# Must match apps/public-site's NEXT_PUBLIC_CMS_ORIGIN (this app's own
# origin) so the postMessage preview channel is accepted on the other end.
VITE_PUBLIC_SITE_BASE_DOMAIN="localhost:3000"
VITE_PUBLIC_SITE_PROTOCOL="http"
